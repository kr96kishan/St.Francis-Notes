# ─── St. Francis Notes — Environment Variables Template ──────────────────────
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and will never be committed.
#
# ─── How to get a Gemini API Key ──────────────────────────────────────────────
#  1. Visit https://aistudio.google.com/apikey
#  2. Sign in with your Google account
#  3. Click "Create API Key" → select or create a project
#  4. Copy the key and paste it below
#
# ─── Production (Cloudflare Pages / Netlify) ──────────────────────────────────
#  Add VITE_GEMINI_API_KEY as an Environment Variable in your hosting dashboard.
#  Cloudflare: Pages → Settings → Environment Variables
#  Netlify:    Site → Site configuration → Environment Variables

VITE_GEMINI_API_KEY=your_gemini_api_key_here
